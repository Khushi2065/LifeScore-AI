{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    "jsx": "react-jsx",

    "strict": false,
    "skipLibCheck": true,
    "isolatedModules": true,
    "allowJs": true,

    "experimentalDecorators": true,
    "useDefineForClassFields": false,

    
    "paths": {
      "@/*": ["./*"]
    },

    "noEmit": true
  }
}